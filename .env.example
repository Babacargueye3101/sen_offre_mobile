# Azure OpenAI Configuration
# Copiez ce fichier en .env et remplissez avec vos vraies clés

# OpenAI API Key (standard)
OPENAI_API_KEY=your_openai_api_key_here

# Azure OpenAI Endpoint
OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/

# Azure OpenAI API Key
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here

# Azure OpenAI API Version
AZURE_OPENAI_API_VERSION=2023-05-15

# Azure OpenAI Deployment Name
AZURE_OPENAI_DEPLOYMENT_GPT_35_TURBO=gpt-35-turbo

# Azure OpenAI Model Version
AZURE_OPENAI_MODEL_VERSION_GPT_35_TURBO=0125

# Use Azure OpenAI (True/False)
USE_AZURE_OPENAI=True
